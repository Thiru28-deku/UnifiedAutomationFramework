<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Unified Test Suite" parallel="methods" data-provider-thread-count="4">
    <listeners>
        <listener class-name="com.utf.listeners.ListenerClass"/>
        <listener class-name="com.utf.listeners.AnnotationTransformer"/>
        <listener class-name="com.utf.listeners.MethodInterceptor"/>
    </listeners>
    <test thread-count="1" name="UI Tests">
        <classes>
            <class name="com.utf.tests.ui.LoginTest"/>
            <class name="com.utf.tests.ui.SignupTest"/>
        </classes>
    </test>
</suite>